# Email Configuration for Development
# Copy this file to .env and update with your actual email settings

# Gmail Configuration (for development)
# IMPORTANT: You need to enable "Less secure app access" or use an App Password
# Go to: https://myaccount.google.com/security
# Enable 2-Step Verification, then create an App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-digit-app-password
DEFAULT_FROM_EMAIL=noreply@ssgiinterns.com

# Alternative: Use a test email service
# EMAIL_HOST=smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_USE_TLS=False
# EMAIL_HOST_USER=your-mailtrap-username
# EMAIL_HOST_PASSWORD=your-mailtrap-password

# For production, you might want to use:
# EMAIL_HOST=your-smtp-server.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-username
# EMAIL_HOST_PASSWORD=your-password
